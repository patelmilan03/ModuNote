{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "modunote",
            "cwd": "modunote",
            "request": "launch",
            "type": "dart"
        },
        {
            // Debug build (same signing key as "modunote" — will NOT wipe data),
            // but points the app at the deployed backend. The API key/URL live
            // in the gitignored modunote/dart_defines.json (not in this file).
            "name": "modunote (deployed API)",
            "cwd": "modunote",
            "request": "launch",
            "type": "dart",
            "toolArgs": [
                "--dart-define-from-file=dart_defines.json"
            ]
        },
        {
            "name": "modunote (profile mode)",
            "cwd": "modunote",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "modunote (release mode)",
            "cwd": "modunote",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        }
    ]
}